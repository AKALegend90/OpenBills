{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenBills",
  "version": "1.0.0",
  "identifier": "app.openbills.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenBills",
        "width": 1180,
        "height": 780,
        "minWidth": 900,
        "minHeight": 640
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
